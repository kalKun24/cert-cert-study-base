# E2Eテスト用環境変数
# このファイルをコピーして .env.e2e.local を作成し、実際の値を設定してください
# .env.e2e.local は .gitignore の .env.*.local パターンで除外されています
#
# 使用方法:
#   cp frontend/.env.e2e.example frontend/.env.e2e.local
#   # .env.e2e.local に実際のパスワードを設定する
#   (export $(cat frontend/.env.e2e.local | xargs) && npm run e2e)
#
# 未設定の場合はローカル開発用シードデータのデフォルト値が使われます

# 管理者ユーザーの認証情報
E2E_ADMIN_USERNAME=admin
E2E_ADMIN_PASSWORD=

# テストユーザーの共通パスワード
E2E_TEST_USER_PASSWORD=
