# ============================================================
# バックエンド設定
# ============================================================

# サーバーポート（デフォルト: 8080）
PORT=8080

# CORS 許可オリジン（カンマ区切りで複数指定可。未設定時はすべてのオリジンを許可）
# 本番は GitHub Actions vars.FRONTEND_URL から cd.yml 経由で注入
# ローカルでは未設定（* 許可）で問題なし
# CORS_ALLOWED_ORIGINS=https://your-frontend.example.com

# JWT 署名用シークレットキー（本番は GCP Secret Manager から注入）
# 生成例: openssl rand -base64 32
# 【重要】この値を git にコミットしないこと。.env は .gitignore 管理対象です。
JWT_SECRET=your-jwt-secret-here

# GCP プロジェクト ID（Firestore 接続に必要）
GCP_PROJECT_ID=your-gcp-project-id

# GCS バケット名
GCS_BUCKET=your-gcs-bucket-name

# GCS エミュレータ（ローカル開発・CI 用）
# 設定されている場合は実 GCS の代わりに fake-gcs-server を使用する
# docker-compose 経由の場合は自動設定されるため .env への記載は不要
# make up を使わず直接 go run する場合は下記をコメントアウト
# GCS_EMULATOR_HOST=http://localhost:4443

# Firestore エミュレータ（ローカル開発・CI 用）
# 設定されている場合は実 Firestore の代わりにエミュレータを使用する
# make up を使わず直接 go run する場合は下記をコメントアウト
# FIRESTORE_EMULATOR_HOST=127.0.0.1:8080

# ============================================================
# フロントエンド設定
# ============================================================

# バックエンド API の URL（Vite 開発サーバーのプロキシ先）
VITE_API_TARGET=http://localhost:8080

# ============================================================
# 初回 admin ユーザー seed 設定
# ============================================================
# 以下の 3 つがすべて設定されており、かつユーザーストアが空の場合のみ
# サーバー起動時に admin ユーザーを自動作成します。
# ユーザーが 1 件でも存在する場合はスキップします（冪等）。
#
# 【注意】初回起動後は SEED_ADMIN_PASSWORD の環境変数を削除してください。
# 本番環境では GCP Secret Manager から注入することを推奨します。

SEED_ADMIN_USERNAME=admin
SEED_ADMIN_PASSWORD=change-me-immediately
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_DISPLAY_NAME=Administrator
